# Copy to .env.local for local dev, and set these in Vercel → Settings → Environment Variables.

# Supabase (public client keys — safe to expose; row-level security protects data)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_xxx

# Only this account receives Gmail e-transfer income auto-detection; everyone
# else uses their own manual income. Set to the email that owns the Gmail mailbox.
OWNER_EMAIL=you@email.com

# Gmail income detection (already configured in Vercel from earlier)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=
